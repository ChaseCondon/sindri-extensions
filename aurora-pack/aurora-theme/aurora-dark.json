{
  "id": "sindri-aurora-dark",
  "name": "Aurora Dark",
  "kind": "dark",
  "ui": {
    "--bg":            "#0B0A18",
    "--bg-panel":      "#0E0D1F",
    "--bg-chrome":     "#090816",
    "--bg-hover":      "rgba(176,108,255,0.07)",
    "--border":        "#1C1830",
    "--border-subtle": "#141128",
    "--text":          "#C5BDDC",
    "--text-dim":      "#5A5272",
    "--accent":        "#B06CFF",
    "--accent-tint":   "rgba(176,108,255,0.14)",
    "--danger":        "#FF5A6E"
  },
  "glow": {
    "--glow-color":         "176,108,255",
    "--glow-accent":        "0 0 10px rgba(176,108,255,.5)",
    "--glow-accent-strong": "0 0 18px rgba(176,108,255,.65),0 0 36px rgba(176,108,255,.28)"
  },
  "editor": {
    "bg":              "#09081A",
    "fg":              "#C5BDDC",
    "caret":           "#B06CFF",
    "selection":       "#231B40",
    "activeLine":      "#0E0C1E",
    "gutter.bg":       "#09081A",
    "gutter.fg":       "#302850",
    "gutter.activeFg": "#7055A0",
    "matchingBracket": "#221A44"
  },
  "syntax": {
    "keyword":        { "color": "#C490FF" },
    "controlKeyword": { "color": "#C490FF" },
    "string":         { "color": "#00D4B4" },
    "number":         { "color": "#79B8FF" },
    "bool":           { "color": "#79B8FF" },
    "comment":        { "color": "#3E3460", "fontStyle": "italic" },
    "function":       { "color": "#E0B0FF" },
    "type":           { "color": "#D4A8FF" },
    "variable":       { "color": "#C5BDDC" },
    "property":       { "color": "#9E90C0" },
    "operator":       { "color": "#B06CFF" },
    "punctuation":    { "color": "#5A5272" },
    "tag":            { "color": "#C490FF" },
    "attribute":      { "color": "#00D4B4" },
    "heading":        { "color": "#E0B0FF" },
    "link":           { "color": "#B06CFF" },
    "regexp":         { "color": "#00D4B4" },
    "escape":         { "color": "#C490FF" }
  }
}
