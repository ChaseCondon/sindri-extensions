{
  "$schema": "./node_modules/@sindri/api/manifest.schema.json",
  "id": "sindri.now-playing",
  "type": "extension",
  "name": "Now Playing",
  "version": "0.1.0",
  "publisher": "sindri",
  "description": "Shows the current media track in the status bar with a full player panel (album art, controls, animated waveform scrubber).",
  "categories": [
    "UI Extension"
  ],
  "permissions": [
    "sindri.env",
    "sindri.ui"
  ],
  "engines": {
    "sindri": ">=0.1.0"
  },
  "main": "dist/extension.js",
  "contributes": {
    "webviewPanels": [
      {
        "id": "sindri.now-playing",
        "title": "Now Playing",
        "defaultDock": "bottom"
      }
    ]
  }
}
